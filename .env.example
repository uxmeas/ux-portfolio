# UX Portfolio Environment Variables
# Copy this file to .env.local and fill in your values

# === DEVELOPMENT SETTINGS ===
NODE_ENV=development
PORT=8000
NEXTJS_PORT=3000

# === PORTFOLIO SETTINGS ===
PORTFOLIO_NAME="UX Meas Portfolio"
PORTFOLIO_URL="https://uxmeas.netlify.app"
AUTHOR_NAME="UX Meas"
AUTHOR_EMAIL="hello@uxmeas.com"

# === CASE STUDY GENERATOR ===
NEXT_TELEMETRY_DISABLED=1
CASE_STUDY_OUTPUT_DIR="./case-studies"
TEMPLATE_DIR="./src/tools/case-study-generator/components/templates"

# === BUILD OPTIMIZATION ===
ENABLE_IMAGE_OPTIMIZATION=true
IMAGE_QUALITY=85
ENABLE_CSS_MINIFICATION=true
ENABLE_JS_MINIFICATION=true

# === TESTING CONFIGURATION ===
LIGHTHOUSE_BUDGET_FILE="infrastructure/config/lighthouse-budget.json"
ACCESSIBILITY_STANDARD="WCAG2AA"
PERFORMANCE_THRESHOLD=90
ACCESSIBILITY_THRESHOLD=95
BEST_PRACTICES_THRESHOLD=90
SEO_THRESHOLD=90

# === DEVELOPMENT TOOLS ===
ENABLE_HOT_RELOAD=true
ENABLE_SOURCE_MAPS=true
ENABLE_PRETTIER=true
ENABLE_ESLINT=true

# === DOCKER SETTINGS ===
COMPOSE_PROJECT_NAME=ux-portfolio
DOCKER_BUILDKIT=1

# === DEPLOYMENT SETTINGS ===
# NOTE: These are for reference only - actual deployment requires manual approval
STAGING_URL="https://staging--uxmeas.netlify.app"
PRODUCTION_URL="https://uxmeas.netlify.app"
DEPLOY_BRANCH="main"

# === API KEYS (if needed) ===
# ANALYTICS_ID=
# SENTRY_DSN=
# HOTJAR_ID=

# === SECURITY HEADERS ===
ENABLE_SECURITY_HEADERS=true
CSP_ENABLED=true
HSTS_MAX_AGE=31536000

# === LOCAL SSL (optional) ===
# ENABLE_HTTPS=false
# SSL_CERT_PATH=
# SSL_KEY_PATH=

# === MONITORING ===
ENABLE_ERROR_REPORTING=false
ENABLE_PERFORMANCE_MONITORING=false

# === FEATURE FLAGS ===
ENABLE_CASE_STUDY_GENERATOR=true
ENABLE_PORTFOLIO_EDITOR=false
ENABLE_DARK_MODE=false
ENABLE_ANIMATIONS=true

# === CONTENT SETTINGS ===
DEFAULT_LANGUAGE="en"
ENABLE_MULTILANG=false
MAX_CASE_STUDIES=20

# === PERFORMANCE SETTINGS ===
ENABLE_LAZY_LOADING=true
ENABLE_CRITICAL_CSS=true
ENABLE_RESOURCE_HINTS=true

# === DEVELOPMENT DEBUGGING ===
DEBUG_MODE=false
VERBOSE_LOGGING=false
SHOW_COMPONENT_BOUNDARIES=false